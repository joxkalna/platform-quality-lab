## Local Kind cluster credentials — copy to .env and fill in
## cp .env.example .env

POSTGRES_USER=pact_admin
POSTGRES_PASSWORD=<your-password>
POSTGRES_DB=pact-broker

PACT_BROKER_AUTH_USERNAME=pact_user
PACT_BROKER_AUTH_PASSWORD=<your-password>
PACT_BROKER_AUTH_RO_USERNAME=read_user
PACT_BROKER_AUTH_RO_PASSWORD=<your-password>
